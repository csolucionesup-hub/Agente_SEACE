# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el archivo .env al repositorio

# ── API Key interna ──────────────────────────────────────────────────────────
# Si se define, todo /api/* (salvo /api/health y /api/config) exige la cabecera
# X-API-Key (modo admin/compatibilidad). Funciona en paralelo al login de Google.
# Deja vacío para desactivar esta vía.
LICITASCAN_API_KEY=

# ── Supabase Auth (login con Google) ────────────────────────────────────────
# Si ambas se definen, /api/* exige un token de Supabase (o la X-API-Key de arriba)
# y el frontend muestra "Entrar con Google". La anon key es pública por diseño.
# Salen del dashboard de Supabase (Project Settings > API).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Gemini (análisis de documentos) ─────────────────────────────────────────
GEMINI_API_KEY=

# ── Telegram (alertas de eventos comerciales) ───────────────────────────────
# Obtén un bot en @BotFather y usa /getid para el chat_id de tu grupo/canal.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Webhook genérico (opcional) ─────────────────────────────────────────────
# URL donde se hará POST con el JSON de eventos nuevos.
LICITASCAN_WEBHOOK_URL=

# ── Scheduler embebido (worker --serve) ─────────────────────────────────────
# Intervalo en minutos entre cada ciclo del worker en modo servidor.
# Default: 30 minutos.
LICITASCAN_SCHEDULE_MINUTES=30

# ── Búsqueda SEACE ───────────────────────────────────────────────────────────
# TTL en segundos del caché de búsqueda (default: 600 = 10 min).
LICITASCAN_SEARCH_CACHE_TTL=600
# Deadline en segundos para cortar un crawl en vivo (default: 20).
LICITASCAN_SEARCH_DEADLINE=20

# ── SEACE Playwright (evidencia visual) ─────────────────────────────────────
SEACE_HEADLESS=true
SEACE_KEYWORDS=PUENTE,CARRETERA,PILOTE
