# Copia este archivo como .env y rellena tus valores reales
# NUNCA subas el archivo .env al repositorio

# API Key de Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_api_key_aqui

# API key para proteger el backend web (opcional).
# Si se define, todo /api/* (salvo /api/health) exige la cabecera X-API-Key con
# este valor. Si se deja vacío, la autenticación queda desactivada.
LICITASCAN_API_KEY=
